NODE_ENV=development
PORT=8080

# Google Cloud (required for Firestore + Vision API)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Sarvam AI (required for NLP recommendations & chat)
SARVAM_API_KEY=your-sarvam-api-key
SARVAM_API_URL=https://api.sarvam.ai/v1

# Vision API (set to true to use Google Vision instead of mock)
VISION_API_ENABLED=false

# CORS - comma separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Image Processing
MAX_IMAGE_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# Gamification Points
POINTS_PER_SCAN=10
POINTS_PER_HIGH_SCORE=20
POINTS_PER_DAILY_LOG=15
STREAK_RESET_HOURS=48

# Nutrition Thresholds
HEALTHY_SCORE_THRESHOLD=80
PROTEIN_GOAL_GRAMS=50
FIBER_GOAL_GRAMS=25
